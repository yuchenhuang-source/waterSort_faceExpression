  },
  "peerDependencies": {
    "phaser": "^3.80.0"
  },
  "devDependencies": {
    "phaser": "^3.80.0",
    "typescript": "^5.2.2"
  },
  "files": [
    "dist",
    "cv-bridge"
  ]
}
