{
  "name": "@ballsort-multi/phaser-cv",
  "version": "1.0.0",
  "description": "Color-encoded instance segmentation for Phaser games - CV bridge, integration, and Python server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
